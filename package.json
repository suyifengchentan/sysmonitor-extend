{
  "name": "sysmonitor-extend",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.2.1-beta",
  "publisher": "LiChenxi",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/lcx-0504/sysmonitor",
  "bugs": {
    "url": "https://github.com/lcx-0504/sysmonitor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lcx-0504/sysmonitor.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning",
    "Data Science"
  ],
  "keywords": [
    "system",
    "monitor",
    "cpu",
    "gpu",
    "remote"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sysmonitor-container",
          "title": "%viewTitle%",
          "icon": "./icon.svg"
        }
      ]
    },
    "views": {
      "sysmonitor-container": [
        {
          "type": "webview",
          "id": "sysmonitor.panel",
          "name": "%viewName%"
        }
      ]
    },
    "commands": [
      {
        "command": "sysmonitor.openPanel",
        "title": "%cmdOpen%"
      }
    ],
    "configuration": {
      "title": "System Monitor",
      "properties": {
        "sysmonitor.refreshInterval": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 30,
          "description": "Refresh interval in seconds"
        },
        "sysmonitor.statusBar": {
          "type": "object",
          "default": {
            "barEnabled": true,
            "alignment": "left",
            "priority": 10,
            "cpu": true,
            "ram": true,
            "net": "off",
            "ssh": false,
            "gpu": {
              "summary": true,
              "mode": "off",
              "cards": [],
              "firstN": 2,
              "metric": "both",
              "skipIdle": false
            }
          },
          "description": "Status bar display configuration"
        },
        "sysmonitor.disk": {
          "type": "object",
          "default": {
            "mountFilter": "default",
            "hideParentMounts": true
          },
          "description": "Disk monitoring settings"
        },
        "sysmonitor.display": {
          "type": "object",
          "default": {
            "charts": true,
            "sparkMinutes": 5,
            "gpuHighlight": true
          },
          "description": "Display settings"
        },
        "sysmonitor.gpuBackend": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "nvidia",
            "amd",
            "intel"
          ],
          "description": "GPU monitoring backend. 'auto' auto-detects by probing available CLI tools."
        },
        "sysmonitor.panelCards": {
          "type": "object",
          "default": {
            "cpu": true,
            "ram": true,
            "gpu": true,
            "network": true,
            "disk": true,
            "ssh": false
          },
          "properties": {
            "cpu": {
              "type": "boolean",
              "description": "Show CPU card"
            },
            "ram": {
              "type": "boolean",
              "description": "Show RAM card"
            },
            "gpu": {
              "type": "boolean",
              "description": "Show GPU cards"
            },
            "network": {
              "type": "boolean",
              "description": "Show Network card"
            },
            "disk": {
              "type": "boolean",
              "description": "Show Disk card"
            },
            "ssh": {
              "type": "boolean",
              "description": "Show SSH traffic card (only when in SSH session)"
            }
          },
          "description": "Dashboard card visibility toggles"
        }
      }
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}
